# Copy to .env.local and fill values. Never commit secrets.

# --- Auth ---
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# --- Database (Neon) — use pooler URLs in serverless ---
# If you use the Vercel → Neon integration, DATABASE_URL is set for you; MSS also reads it as a fallback.
LOCAL_POSTGRES_URL=
# PREVIEW_POSTGRES_URL=   # Vercel Preview (optional if DATABASE_URL is scoped per env)
# PRODUCTION_POSTGRES_URL= # Vercel Production (optional if DATABASE_URL is scoped per env)
# DATABASE_URL=           # Often injected by Vercel Neon integration

# --- Config Sheet (public CSV export) ---
SITE_CONFIG_SHEET_ID=
SITE_CONFIG_GID_PROD=
SITE_CONFIG_GID_STAGE=

# --- Optional overrides ---
APP_ENV=local
DEV_AUTH_BYPASS=true
DEV_AUTH_EMAIL=wvanderlaan@gmail.com
NEXT_PUBLIC_DEV_AUTH_BYPASS=true
NEXT_PUBLIC_DEV_AUTH_EMAIL=wvanderlaan@gmail.com

# --- Email (SMTP) ---
# Gmail: host smtp.gmail.com, user = full address, password = Google "App Password" (2FA required).
# See https://support.google.com/accounts/answer/185833
EMAIL_SERVER_HOST=
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER=
EMAIL_SERVER_PASSWORD=
EMAIL_SERVER_SECURE=false
# Use the same mailbox as EMAIL_SERVER_USER (or "Name <address>").
EMAIL_FROM=

# --- Vercel Blob (avatar upload) ---
BLOB_READ_WRITE_TOKEN=

# --- First-time DB init (optional; curl with header) ---
DATABASE_BOOTSTRAP_SECRET=
